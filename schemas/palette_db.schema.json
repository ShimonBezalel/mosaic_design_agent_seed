{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaletteDB",
  "type": "object",
  "required": ["version", "tiles"],
  "properties": {
    "version": {"type": "string"},
    "source": {"type": "string"},
    "notes": {"type": "string"},
    "tiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tile_id", "name", "hex", "inventory_level"],
        "properties": {
          "tile_id": {"type": "string", "pattern": "^[a-z0-9_\\-]+$"},
          "name": {"type": "string"},
          "hex": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
          "inventory_level": {"type": "string", "enum": ["low", "medium", "high", "unknown"]},
          "surface": {"type": "string", "enum": ["matte", "gloss", "mixed", "unknown"]},
          "material": {"type": "string"},
          "break_profile": {"type": "string", "enum": ["large", "medium", "small", "splintery", "mixed", "unknown"]},
          "preferred_uses": {"type": "array", "items": {"type": "string"}},
          "avoid_uses": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

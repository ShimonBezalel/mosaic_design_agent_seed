{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConceptPackage",
  "type": "object",
  "required": ["run_id", "project_name", "assumptions", "questions", "concepts", "recommended_next_step"],
  "properties": {
    "run_id": {"type": "string"},
    "project_name": {"type": "string"},
    "mode": {"type": "string", "enum": ["stub", "real_model_stub_images", "real_images", "openai-image", "gemini-image"]},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "questions": {"type": "array", "items": {"type": "string"}},
    "palette_summary": {"type": "string"},
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["concept_id", "name", "intent", "composition", "palette_tile_ids", "image_prompts", "critique"],
        "properties": {
          "concept_id": {"type": "string"},
          "name": {"type": "string"},
          "intent": {"type": "string"},
          "composition": {"type": "string"},
          "locked_elements": {"type": "array", "items": {"type": "string"}},
          "flexible_elements": {"type": "array", "items": {"type": "string"}},
          "mosaic_grammar": {"type": "string"},
          "palette_tile_ids": {"type": "array", "items": {"type": "string"}},
          "image_prompts": {
            "type": "object",
            "properties": {
              "openai": {"type": "string"},
              "gemini_nano_banana": {"type": "string"},
              "negative_prompt": {"type": "string"}
            },
            "additionalProperties": false
          },
          "image_results": {"type": "array", "items": {"type": "object"}},
          "critique": {
            "type": "object",
            "required": ["scores", "notes", "risks"],
            "properties": {
              "scores": {
                "type": "object",
                "properties": {
                  "palette_adherence": {"type": "integer", "minimum": 1, "maximum": 5},
                  "distance_readability": {"type": "integer", "minimum": 1, "maximum": 5},
                  "tile_buildability": {"type": "integer", "minimum": 1, "maximum": 5},
                  "text_survivability": {"type": "integer", "minimum": 1, "maximum": 5},
                  "style_fit": {"type": "integer", "minimum": 1, "maximum": 5},
                  "novelty": {"type": "integer", "minimum": 1, "maximum": 5}
                },
                "additionalProperties": false
              },
              "notes": {"type": "array", "items": {"type": "string"}},
              "risks": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "recommended_next_step": {"type": "string"}
  },
  "additionalProperties": false
}
